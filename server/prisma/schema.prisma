generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  country      String?
  role         String        @default("procurement_officer")
  vendorId     String?
  vendor       Vendor?       @relation(fields: [vendorId], references: [id])
  rfqs         Rfq[]         @relation("RfqCreatedBy")
  approvals    Approval[]
  activities   ActivityLog[]
  createdAt    DateTime      @default(now())
}

model Vendor {
  id             String          @id @default(cuid())
  name           String
  category       String?
  gstNo          String?
  email          String?
  phone          String?
  address        String?
  status         String          @default("active")
  rating         Float           @default(0)
  users          User[]
  quotations     Quotation[]
  invitations    RfqInvitation[]
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]
  createdAt      DateTime        @default(now())
}

model Rfq {
  id          String          @id @default(cuid())
  title       String
  category    String?
  description String?
  deadline    DateTime?
  status      String          @default("open")
  createdById String?
  createdBy   User?           @relation("RfqCreatedBy", fields: [createdById], references: [id])
  items       RfqItem[]
  invitations RfqInvitation[]
  quotations  Quotation[]
  createdAt   DateTime        @default(now())
}

model RfqItem {
  id       String @id @default(cuid())
  rfqId    String
  rfq      Rfq    @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  name     String
  quantity Int    @default(1)
  unit     String @default("NOS")
}

model RfqInvitation {
  id       String @id @default(cuid())
  rfqId    String
  rfq      Rfq    @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  status   String @default("invited")

  @@unique([rfqId, vendorId])
}

model Quotation {
  id            String          @id @default(cuid())
  rfqId         String
  rfq           Rfq             @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendorId      String
  vendor        Vendor          @relation(fields: [vendorId], references: [id])
  deliveryDays  Int             @default(0)
  paymentTerms  String?
  notes         String?
  taxRate       Float           @default(18)
  subtotal      Float           @default(0)
  taxAmount     Float           @default(0)
  total         Float           @default(0)
  status        String          @default("submitted")
  items         QuotationItem[]
  approvals     Approval[]
  purchaseOrder PurchaseOrder?
  createdAt     DateTime        @default(now())
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  name        String
  quantity    Int       @default(1)
  unitPrice   Float     @default(0)
  total       Float     @default(0)
}

model Approval {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  stage       Int       @default(1)
  status      String    @default("pending")
  remarks     String?
  approverId  String?
  approver    User?     @relation(fields: [approverId], references: [id])
  decidedAt   DateTime?
  createdAt   DateTime  @default(now())
}

model PurchaseOrder {
  id          String    @id @default(cuid())
  poNumber    String    @unique
  quotationId String    @unique
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  vendorId    String
  vendor      Vendor    @relation(fields: [vendorId], references: [id])
  status      String    @default("issued")
  poDate      DateTime  @default(now())
  invoice     Invoice?
  createdAt   DateTime  @default(now())
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  purchaseOrderId String        @unique
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  vendorId        String
  vendor          Vendor        @relation(fields: [vendorId], references: [id])
  invoiceDate     DateTime      @default(now())
  dueDate         DateTime?
  subtotal        Float         @default(0)
  cgst            Float         @default(0)
  sgst            Float         @default(0)
  total           Float         @default(0)
  status          String        @default("pending")
  items           InvoiceItem[]
  createdAt       DateTime      @default(now())
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  name      String
  quantity  Int     @default(1)
  unitPrice Float   @default(0)
  total     Float   @default(0)
}

model ActivityLog {
  id         String   @id @default(cuid())
  type       String
  message    String
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  entityType String?
  entityId   String?
  createdAt  DateTime @default(now())
}

model EmailLog {
  id          String   @id @default(cuid())
  to          String
  subject     String
  body        String
  status      String   @default("simulated")
  relatedType String?
  relatedId   String?
  createdAt   DateTime @default(now())
}
