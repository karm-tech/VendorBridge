# ─────────────────────────────────────────────
# VendorBridge — .gitignore
# Stack-agnostic. Trim sections you don't use.
# ─────────────────────────────────────────────

# Environment & secrets
.env
.env.*
!.env.example
*.pem
*.key
secrets.json
config.local.*

# Dependencies
node_modules/
.pnp/
.pnp.js
vendor/
__pycache__/
*.py[cod]
.venv/
venv/
env/
.Python

# Build / output
dist/
build/
out/
.next/
.nuxt/
.cache/
coverage/
*.tsbuildinfo
target/          # Java/Rust
*.class
*.jar
*.war

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Databases (local/dev)
*.sqlite
*.sqlite3
*.db

# Uploads / generated files (invoices, attachments)
uploads/
generated/
tmp/
temp/

# Testing
.pytest_cache/
.coverage
htmlcov/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*.sublime-*

# OS
.DS_Store
Thumbs.db
desktop.ini

# Misc
*.bak
*.local
