# Frontend (Vite) talks to the local API through a dev proxy — no env is needed here by default.
#
# Backend environment variables live in server/.env (created during backend setup):
#   PORT=4000
#   DATABASE_URL="file:./dev.db"
#   JWT_SECRET=change-me-in-production
#
# Optional outgoing email (Nodemailer SMTP) — leave blank to simulate "email sent":
#   SMTP_HOST=
#   SMTP_PORT=
#   SMTP_USER=
#   SMTP_PASS=
